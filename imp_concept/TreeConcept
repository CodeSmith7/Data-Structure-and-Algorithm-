<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tree DSA — Complete Pattern Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#08090f;--bg2:#0d0f1a;--bg3:#111525;--bg4:#161c2e;--surface:#1a2038;
  --border:#1e2840;--border2:#28345a;
  --text:#dde4f8;--text2:#7a89b8;--text3:#3d4d78;
  --accent:#3d8ef8;--accent2:#6aaafb;
  --green:#27d97f;--green-d:rgba(39,217,127,.1);--green-b:rgba(39,217,127,.2);
  --amber:#f5a623;--amber-d:rgba(245,166,35,.08);--amber-b:rgba(245,166,35,.2);
  --red:#f05060;--red-d:rgba(240,80,96,.08);--red-b:rgba(240,80,96,.2);
  --purple:#b07ef8;--teal:#22d4c0;--pink:#f472b6;
  --r:8px;--r2:12px;--r3:18px;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Manrope',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;}

/* ── HERO ── */
.hero{
  padding:52px 44px 44px;
  background:var(--bg2);
  border-bottom:1px solid var(--border);
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 70% at 80% 30%,rgba(61,142,248,.08) 0%,transparent 65%),
    radial-gradient(ellipse 40% 50% at 10% 80%,rgba(39,217,127,.05) 0%,transparent 60%);
  pointer-events:none;
}
.hero-tag{
  font-family:'Fira Code',monospace;font-size:10px;letter-spacing:3px;
  text-transform:uppercase;color:var(--accent);margin-bottom:14px;opacity:.9;
}
.hero-title{
  font-size:clamp(30px,5vw,56px);font-weight:800;
  line-height:1.04;letter-spacing:-1.5px;margin-bottom:12px;
}
.hero-title .hl{color:var(--green);}
.hero-sub{
  font-family:'Fira Code',monospace;font-size:12px;
  color:var(--text2);margin-bottom:36px;max-width:560px;line-height:1.7;
}

/* Patterns nav */
.nav-row{display:flex;gap:8px;flex-wrap:wrap;}
.nav-chip{
  padding:8px 16px;border-radius:99px;cursor:pointer;
  font-family:'Fira Code',monospace;font-size:11px;font-weight:500;
  border:1px solid var(--border2);
  background:transparent;color:var(--text2);
  transition:all .18s ease;
}
.nav-chip:hover{background:var(--bg4);color:var(--text);}
.nav-chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.nav-chip.c2{}.nav-chip.c2.active{background:var(--green);border-color:var(--green);}
.nav-chip.c3{}.nav-chip.c3.active{background:var(--purple);border-color:var(--purple);}
.nav-chip.c4{}.nav-chip.c4.active{background:var(--amber);border-color:var(--amber);}
.nav-chip.c5{}.nav-chip.c5.active{background:var(--teal);border-color:var(--teal);color:#000;}
.nav-chip.c6{}.nav-chip.c6.active{background:var(--pink);border-color:var(--pink);}
.nav-chip.c7{}.nav-chip.c7.active{background:var(--red);border-color:var(--red);}

/* ── LAYOUT ── */
.main{padding:40px 44px;max-width:1060px;}
.section{display:none;animation:fadeUp .28s ease;}
.section.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* ── SECTION HEADER ── */
.sec-header{display:flex;align-items:flex-start;gap:18px;margin-bottom:28px;}
.sec-num{
  width:54px;height:54px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-family:'Fira Code',monospace;font-size:18px;font-weight:700;flex-shrink:0;
}
.sn1{background:rgba(61,142,248,.15);color:var(--accent);border:1.5px solid rgba(61,142,248,.3);}
.sn2{background:rgba(39,217,127,.12);color:var(--green);border:1.5px solid var(--green-b);}
.sn3{background:rgba(176,126,248,.12);color:var(--purple);border:1.5px solid rgba(176,126,248,.3);}
.sn4{background:rgba(245,166,35,.1);color:var(--amber);border:1.5px solid var(--amber-b);}
.sn5{background:rgba(34,212,192,.1);color:var(--teal);border:1.5px solid rgba(34,212,192,.3);}
.sn6{background:rgba(244,114,182,.1);color:var(--pink);border:1.5px solid rgba(244,114,182,.3);}
.sn7{background:rgba(240,80,96,.1);color:var(--red);border:1.5px solid var(--red-b);}
.sec-title{font-size:24px;font-weight:800;letter-spacing:-.4px;margin-bottom:4px;}
.sec-desc{font-family:'Fira Code',monospace;font-size:11.5px;color:var(--text2);line-height:1.5;}

/* ── CARDS ── */
.card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--r3);padding:24px 28px;margin-bottom:18px;
}
.card-lbl{
  font-family:'Fira Code',monospace;font-size:9px;letter-spacing:2px;
  text-transform:uppercase;margin-bottom:12px;font-weight:600;
}
.cl1{color:var(--accent);}
.cl2{color:var(--green);}
.cl3{color:var(--purple);}
.cl4{color:var(--amber);}
.cl5{color:var(--teal);}
.cl6{color:var(--pink);}
.cl7{color:var(--red);}
.clg{color:var(--text3);}
.card-title{font-size:16px;font-weight:700;margin-bottom:12px;letter-spacing:-.2px;}

/* ── CODE ── */
.code{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r2);padding:18px 20px;
  font-family:'Fira Code',monospace;font-size:12.5px;
  line-height:1.8;overflow-x:auto;margin:12px 0;
  white-space:pre;
}
.kw{color:#79b8ff;}.tp{color:var(--green);}.fn{color:#f9c74f;}
.cm{color:var(--text3);font-style:italic;}.nm{color:#f38ba8;}.st{color:#a9d4a2;}
.op{color:var(--text2);}

/* ── INSIGHT / WARN ── */
.insight{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:var(--r2);padding:14px 18px;
  font-family:'Fira Code',monospace;font-size:12px;
  color:var(--text2);line-height:1.7;margin:12px 0;
}
.insight strong{color:var(--text);}
.warn{
  background:var(--amber-d);border:1px solid var(--amber-b);
  border-radius:var(--r);padding:12px 16px;
  font-family:'Fira Code',monospace;font-size:12px;
  color:var(--amber);line-height:1.7;margin:10px 0;
}
.warn strong{font-weight:700;}
.tip{
  background:var(--green-d);border:1px solid var(--green-b);
  border-radius:var(--r);padding:12px 16px;
  font-family:'Fira Code',monospace;font-size:12px;
  color:var(--green);line-height:1.7;margin:10px 0;
}
.tip strong{font-weight:700;}

/* ── STEPS ── */
.steps{display:flex;flex-direction:column;gap:9px;margin:12px 0;}
.step{
  display:flex;gap:12px;align-items:flex-start;
  padding:11px 14px;background:var(--bg3);
  border-radius:var(--r);border:1px solid var(--border);
}
.step-n{
  width:24px;height:24px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:10px;font-weight:700;flex-shrink:0;
  font-family:'Fira Code',monospace;
}
.step-text{font-family:'Fira Code',monospace;font-size:12px;color:var(--text2);line-height:1.6;}
.step-text strong{color:var(--text);}
.step-text code{background:var(--bg4);padding:1px 5px;border-radius:4px;color:var(--accent2);font-size:11px;}

/* ── GRID ── */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
@media(max-width:700px){.grid2,.grid3{grid-template-columns:1fr;}}

/* ── PROBLEMS LIST ── */
.prob-list{display:flex;flex-direction:column;gap:8px;margin:12px 0;}
.prob{
  display:flex;align-items:center;gap:12px;
  padding:10px 14px;background:var(--bg3);
  border-radius:var(--r);border:1px solid var(--border);
  transition:border-color .15s;
}
.prob:hover{border-color:var(--border2);}
.diff{
  font-family:'Fira Code',monospace;font-size:10px;font-weight:700;
  padding:2px 8px;border-radius:4px;flex-shrink:0;
}
.dE{background:var(--green-d);color:var(--green);}
.dM{background:var(--amber-d);color:var(--amber);}
.dH{background:var(--red-d);color:var(--red);}
.prob-name{font-size:13px;font-weight:600;}
.prob-tag{margin-left:auto;font-family:'Fira Code',monospace;font-size:10px;color:var(--text3);}

/* ── BADGES ── */
.badges{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0;}
.badge{
  padding:4px 11px;border-radius:99px;border:1px solid;
  font-family:'Fira Code',monospace;font-size:10px;font-weight:600;
}
.bt{background:rgba(61,142,248,.1);color:var(--accent2);border-color:rgba(61,142,248,.3);}
.bs{background:rgba(176,126,248,.1);color:var(--purple);border-color:rgba(176,126,248,.3);}
.bd{background:var(--red-d);color:var(--red);border-color:var(--red-b);}
.bm{background:var(--amber-d);color:var(--amber);border-color:var(--amber-b);}
.be{background:var(--green-d);color:var(--green);border-color:var(--green-b);}

/* ── TREE VIZ ── */
.tree-viz{
  background:var(--bg);border:1px solid var(--border);
  border-radius:var(--r2);padding:20px;margin:12px 0;
  overflow-x:auto;
}
.tree-viz svg text{font-family:'Fira Code',monospace;}

/* ── COMPARE ── */
.compare{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:12px 0;}
@media(max-width:600px){.compare{grid-template-columns:1fr;}}
.cmp-item{
  padding:14px 16px;border-radius:var(--r2);
  border:1px solid var(--border);background:var(--bg3);
}
.cmp-lbl{
  font-family:'Fira Code',monospace;font-size:9px;letter-spacing:2px;
  text-transform:uppercase;margin-bottom:8px;font-weight:700;
}
.cmp-item p{font-family:'Fira Code',monospace;font-size:11.5px;color:var(--text2);line-height:1.6;}
.cmp-item code{background:var(--bg);padding:1px 5px;border-radius:3px;color:var(--accent2);font-size:11px;}

/* ── KEY BOX ── */
.key-box{
  background:linear-gradient(135deg,rgba(61,142,248,.07),rgba(176,126,248,.06));
  border:1px solid rgba(61,142,248,.2);
  border-radius:var(--r2);padding:16px 20px;margin:12px 0;
}
.kb-title{
  font-family:'Fira Code',monospace;font-size:10px;font-weight:700;
  letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);margin-bottom:10px;
}
.kb-text{font-family:'Fira Code',monospace;font-size:12px;color:var(--text2);line-height:1.7;}
.kb-text strong{color:var(--text);}
.kb-text code{background:var(--bg);padding:1px 5px;border-radius:4px;color:var(--accent2);font-size:11px;}

/* ── PATTERN SUMMARY ── */
.summary{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:var(--r3);padding:28px 32px;margin-top:32px;
}
.sum-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;margin-top:18px;}
.sum-card{
  padding:16px 18px;border-radius:var(--r2);
  border:1px solid var(--border);background:var(--bg3);
}
.sum-num{font-size:22px;font-weight:800;margin-bottom:4px;}
.sum-title{font-size:12px;font-weight:700;margin-bottom:6px;}
.sum-when{font-family:'Fira Code',monospace;font-size:10px;color:var(--text3);line-height:1.6;}

@media(max-width:600px){.main,.hero{padding-left:20px;padding-right:20px;}}
</style>
</head>
