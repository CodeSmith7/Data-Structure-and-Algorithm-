    <button class="nav-chip c7" onclick="show(7,this)">07 · LCA &amp; Ancestors</button>
  </div>
</div>

<div class="main">

<!-- ═══════════════════════════════════════════════
     PATTERN 1 — TRAVERSALS
═══════════════════════════════════════════════ -->
<div class="section active" id="s1">
  <div class="sec-header">
    <div class="sec-num sn1">01</div>
    <div>
      <div class="sec-title">Tree Traversals — The Foundation</div>
      <div class="sec-desc">// Every tree problem is built on top of one of these 4 traversals</div>
    </div>
  </div>

  <!-- Tree Visual -->
  <div class="card">
    <div class="card-lbl cl1">// Visual — Sample Tree</div>
    <div class="tree-viz">
      <svg width="100%" viewBox="0 0 500 200" style="max-height:200px;">
        <!-- edges -->
        <line x1="250" y1="40" x2="150" y2="100" stroke="#28345a" stroke-width="2"/>
        <line x1="250" y1="40" x2="350" y2="100" stroke="#28345a" stroke-width="2"/>
        <line x1="150" y1="100" x2="90" y2="160" stroke="#28345a" stroke-width="2"/>
        <line x1="150" y1="100" x2="210" y2="160" stroke="#28345a" stroke-width="2"/>
        <line x1="350" y1="100" x2="290" y2="160" stroke="#28345a" stroke-width="2"/>
        <line x1="350" y1="100" x2="410" y2="160" stroke="#28345a" stroke-width="2"/>
        <!-- nodes -->
        <circle cx="250" cy="40" r="22" fill="#1a2038" stroke="#3d8ef8" stroke-width="2"/>
        <circle cx="150" cy="100" r="22" fill="#1a2038" stroke="#27d97f" stroke-width="2"/>
        <circle cx="350" cy="100" r="22" fill="#1a2038" stroke="#27d97f" stroke-width="2"/>
        <circle cx="90" cy="160" r="22" fill="#1a2038" stroke="#b07ef8" stroke-width="2"/>
        <circle cx="210" cy="160" r="22" fill="#1a2038" stroke="#b07ef8" stroke-width="2"/>
        <circle cx="290" cy="160" r="22" fill="#1a2038" stroke="#b07ef8" stroke-width="2"/>
        <circle cx="410" cy="160" r="22" fill="#1a2038" stroke="#b07ef8" stroke-width="2"/>
        <!-- labels -->
        <text x="250" y="45" text-anchor="middle" fill="#3d8ef8" font-size="14" font-weight="700">1</text>
        <text x="150" y="105" text-anchor="middle" fill="#27d97f" font-size="14" font-weight="700">2</text>
        <text x="350" y="105" text-anchor="middle" fill="#27d97f" font-size="14" font-weight="700">3</text>
        <text x="90" y="165" text-anchor="middle" fill="#b07ef8" font-size="14" font-weight="700">4</text>
        <text x="210" y="165" text-anchor="middle" fill="#b07ef8" font-size="14" font-weight="700">5</text>
        <text x="290" y="165" text-anchor="middle" fill="#b07ef8" font-size="14" font-weight="700">6</text>
        <text x="410" y="165" text-anchor="middle" fill="#b07ef8" font-size="14" font-weight="700">7</text>
        <!-- role labels -->
        <text x="282" y="32" fill="#3d4d78" font-size="10">Root</text>
        <text x="118" y="92" fill="#3d4d78" font-size="10">L child</text>
        <text x="358" y="92" fill="#3d4d78" font-size="10">R child</text>
        <text x="58" y="152" fill="#3d4d78" font-size="10">Leaf</text>
      </svg>
    </div>
    <div class="grid2" style="margin-top:12px;">
      <div>
        <div style="font-family:'Fira Code',monospace;font-size:11px;color:var(--text2);margin-bottom:6px;">Traversal results:</div>
        <div class="code" style="font-size:11px;padding:12px 14px;">
<span class="cm">// Inorder   (L → Root → R):</span> <span class="nm">4 2 5 1 6 3 7</span>
<span class="cm">// Preorder  (Root → L → R):</span> <span class="nm">1 2 4 5 3 6 7</span>
<span class="cm">// Postorder (L → R → Root):</span> <span class="nm">4 5 2 6 7 3 1</span>
<span class="cm">// Level     (BFS by levels):</span> <span class="nm">1 | 2 3 | 4 5 6 7</span></div>
      </div>
      <div>
        <div style="font-family:'Fira Code',monospace;font-size:11px;color:var(--text2);margin-bottom:6px;">When to use which:</div>
        <div class="insight" style="margin:0;">
          <strong>Inorder</strong> → BST gives sorted output<br>
          <strong>Preorder</strong> → Serialize / copy tree<br>
          <strong>Postorder</strong> → Delete tree, bottom-up calc<br>
          <strong>Level</strong> → Level-wise problems
        </div>
      </div>
    </div>
  </div>

  <!-- All 4 traversals code -->
  <div class="card">
    <div class="card-lbl cl1">// Node Structure + All Traversals</div>
<div class="code"><span class="kw">struct</span> <span class="tp">TreeNode</span> {
    <span class="kw">int</span> val;
    <span class="tp">TreeNode</span> <span class="op">*</span>left, <span class="op">*</span>right;
    <span class="tp">TreeNode</span>(<span class="kw">int</span> x) : val(x), left(<span class="nm">nullptr</span>), right(<span class="nm">nullptr</span>) {}
};

<span class="cm">// ── INORDER (L → Root → R) ─────────────────────────</span>
<span class="kw">void</span> <span class="fn">inorder</span>(<span class="tp">TreeNode</span><span class="op">*</span> root, <span class="tp">vector</span><span class="op">&lt;</span><span class="kw">int</span><span class="op">&gt;&amp;</span> res) {
    <span class="kw">if</span> (!root) <span class="kw">return</span>;
    <span class="fn">inorder</span>(root<span class="op">-&gt;</span>left, res);
    res.push_back(root<span class="op">-&gt;</span>val);       <span class="cm">// process AFTER left</span>
    <span class="fn">inorder</span>(root<span class="op">-&gt;</span>right, res);
}

<span class="cm">// ── PREORDER (Root → L → R) ────────────────────────</span>
<span class="kw">void</span> <span class="fn">preorder</span>(<span class="tp">TreeNode</span><span class="op">*</span> root, <span class="tp">vector</span><span class="op">&lt;</span><span class="kw">int</span><span class="op">&gt;&amp;</span> res) {
    <span class="kw">if</span> (!root) <span class="kw">return</span>;
    res.push_back(root<span class="op">-&gt;</span>val);       <span class="cm">// process BEFORE children</span>
    <span class="fn">preorder</span>(root<span class="op">-&gt;</span>left, res);
    <span class="fn">preorder</span>(root<span class="op">-&gt;</span>right, res);
}

<span class="cm">// ── POSTORDER (L → R → Root) ───────────────────────</span>
<span class="kw">void</span> <span class="fn">postorder</span>(<span class="tp">TreeNode</span><span class="op">*</span> root, <span class="tp">vector</span><span class="op">&lt;</span><span class="kw">int</span><span class="op">&gt;&amp;</span> res) {
    <span class="kw">if</span> (!root) <span class="kw">return</span>;
    <span class="fn">postorder</span>(root<span class="op">-&gt;</span>left, res);
    <span class="fn">postorder</span>(root<span class="op">-&gt;</span>right, res);
    res.push_back(root<span class="op">-&gt;</span>val);       <span class="cm">// process AFTER both children</span>
}

<span class="cm">// ── ITERATIVE INORDER (using stack) ────────────────</span>
<span class="tp">vector</span><span class="op">&lt;</span><span class="kw">int</span><span class="op">&gt;</span> <span class="fn">inorderIter</span>(<span class="tp">TreeNode</span><span class="op">*</span> root) {
    <span class="tp">vector</span><span class="op">&lt;</span><span class="kw">int</span><span class="op">&gt;</span> res;
    <span class="tp">stack</span><span class="op">&lt;</span><span class="tp">TreeNode</span><span class="op">*&gt;</span> st;
    <span class="tp">TreeNode</span><span class="op">*</span> cur <span class="op">=</span> root;
    <span class="kw">while</span> (cur || !st.empty()) {
        <span class="kw">while</span> (cur) { st.push(cur); cur <span class="op">=</span> cur<span class="op">-&gt;</span>left; }
        cur <span class="op">=</span> st.top(); st.pop();
        res.push_back(cur<span class="op">-&gt;</span>val);
        cur <span class="op">=</span> cur<span class="op">-&gt;</span>right;
    }
    <span class="kw">return</span> res;
}</div>
  </div>

  <div class="key-box">
    <div class="kb-title">🔑 The Golden Rule of Tree Traversal</div>
    <div class="kb-text">
      <strong>Every recursive tree function has this skeleton:</strong><br>
      <code>if (!root) return BASE_CASE;</code> ← base case first, always<br>
      Then decide: do you process root <strong>before</strong> (preorder), <strong>between</strong> (inorder), or <strong>after</strong> (postorder) the recursive calls?<br><br>
      <strong>Most tree problems = choosing WHERE to put your logic in this skeleton.</strong>
    </div>
  </div>

  <div class="prob-list">
    <div class="prob"><span class="diff dE">EASY</span><span class="prob-name">LC 144 — Binary Tree Preorder Traversal</span><span class="prob-tag">preorder</span></div>
    <div class="prob"><span class="diff dE">EASY</span><span class="prob-name">LC 94 — Binary Tree Inorder Traversal</span><span class="prob-tag">inorder</span></div>
    <div class="prob"><span class="diff dE">EASY</span><span class="prob-name">LC 145 — Binary Tree Postorder Traversal</span><span class="prob-tag">postorder</span></div>
