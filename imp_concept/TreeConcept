<!-- HERO -->
<div class="hero">
  <div class="hero-tag">// DSA Master Series — Trees</div>
  <div class="hero-title">Tree Patterns<br><span class="hl">Complete Guide</span></div>
  <div class="hero-sub">
    // 7 core patterns · C++ code · Intuition first · Real LC problems<br>
